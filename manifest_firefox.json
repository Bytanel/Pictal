{
	"manifest_version": 2,
	"name": "Pictal",
	"version": "2026.3.3",
	"description": "Enlarge and preview images and videos from links.",
	"homepage_url": "https://github.com/Bytanel/Pictal",
	"web_accessible_resources": [
		"data/sieves.json"
	],
	"permissions": [
		"cookies",
		"downloads",
		"history",
		"storage",
		"webRequest",
		"webRequestBlocking",
		"<all_urls>"
	],
	"content_scripts": [{
		"matches": ["<all_urls>"],
		"js": [
			"content/content.js",
			"lib/videojs/video.js"
		],
		"css": [
			"lib/videojs/video-js.min.css"
		],
		"run_at": "document_start"
	}],
	"incognito": "spanning",
	"background": {
		"scripts": [
			"background/service.js"
		]
	},
	"options_ui": {
		"page": "options/options.html",
		"open_in_tab": true
	}
}
