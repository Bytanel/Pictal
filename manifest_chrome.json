{
	"manifest_version": 3,
	"name": "Pictal",
	"version": "2026.3.3",
	"description": "Enlarge and preview images and videos from links.",
	"homepage_url": "https://github.com/Bytanel/Pictal",
	"action": {
		"default_title": "Pictal v2026.3.3"
	},
	"icons": {
		"64": "common/img/icon_64.png"
	},
	"web_accessible_resources": [{
		"resources": ["data/sieves.json"],
		"matches": ["<all_urls>"]
	}],
	"permissions": [
		"cookies",
		"downloads",
		"history",
		"storage",
		"userScripts",
		"declarativeNetRequest",
		"declarativeNetRequestWithHostAccess"
	],
	"host_permissions": [
		"<all_urls>"
	],
	"background": {
		"service_worker": "background/service.js"
	},
	"incognito": "split",
	"options_ui": {
		"page": "options/options.html",
		"open_in_tab": true
	}
}
